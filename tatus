[32m+[m[32m   "source": [[m
[32m+[m[32m    "MANUAL_PAIRS = [\n",[m
[32m+[m[32m    "    (\"پاکستان\", \"بھارت\"),\n",[m
[32m+[m[32m    "    (\"حکومت\", \"وزیر\"),\n",[m
[32m+[m[32m    "    (\"عدالت\", \"جج\"),\n",[m
[32m+[m[32m    "    (\"معیشت\", \"بینک\"),\n",[m
[32m+[m[32m    "    (\"فوج\", \"دفاع\"),\n",[m
[32m+[m[32m    "    (\"صحت\", \"ہسپتال\"),\n",[m
[32m+[m[32m    "    (\"تعلیم\", \"استاد\"),\n",[m
[32m+[m[32m    "    (\"ڈاکٹر\", \"مریض\"),\n",[m
[32m+[m[32m    "    (\"کرکٹ\", \"میچ\"),\n",[m
[32m+[m[32m    "    (\"ٹیم\", \"کھلاڑی\"),\n",[m
[32m+[m[32m    "    (\"وزیراعظم\", \"حکومت\"),\n",[m
[32m+[m[32m    "    (\"قانون\", \"عدالت\"),\n",[m
[32m+[m[32m    "    (\"ویکسین\", \"بیماری\"),\n",[m
[32m+[m[32m    "    (\"روپے\", \"ڈالر\"),\n",[m
[32m+[m[32m    "    (\"یونیورسٹی\", \"تعلیم\"),\n",[m
[32m+[m[32m    "    (\"امریکہ\", \"روس\"),\n",[m
[32m+[m[32m    "    (\"ایران\", \"امریکہ\"),\n",[m
[32m+[m[32m    "    (\"نجکاری\", \"حصص\"),\n",[m
[32m+[m[32m    "    (\"سولر\", \"بجلی\"),\n",[m
[32m+[m[32m    "    (\"طالبان\", \"افغانستان\"),\n",[m
[32m+[m[32m    "]\n",[m
[32m+[m[32m    "\n",[m
[32m+[m[32m    "def reciprocal_rank(matrix, word2idx, idx2word, query, gold):\n",[m
[32m+[m[32m    "    if query not in word2idx or gold not in word2idx:\n",[m
[32m+[m[32m    "        return None\n",[m
[32m+[m[32m    "\n",[m
[32m+[m[32m    "    matrix_norm = normalize_rows(matrix)\n",[m
[32m+[m[32m    "    qid = word2idx[query]\n",[m
[32m+[m[32m    "    gid = word2idx[gold]\n",[m
[32m+[m[32m    "\n",[m
[32m+[m[32m    "    sims = matrix_norm @ matrix_norm[qid]\n",[m
[32m+[m[32m    "    sims[qid] = -1.0\n",[m
[32m+[m[32m    "\n",[m
[32m+[m[32m    "    ranked_ids = np.argsort(-sims)\n",[m
[32m+[m[32m    "    rank_positions = np.where(ranked_ids == gid)[0]\n",[m
[32m+[m[32m    "\n",[m
[32m+[m[32m    "    if len(rank_positions) == 0:\n",[m
[32m+[m[32m    "        return 0.0\n",[m
[32m+[m[32m    "\n",[m
[32m+[m[32m    "    rank = rank_positions[0] + 1\n",[m
[32m+[m[32m    "    return 1.0 / rank\n",[m
[32m+[m[32m    "\n",[m
[32m+[m[32m    "def compute_mrr_verbose(matrix, word2idx, idx2word, pairs):\n",[m
[32m+[m[32m    "    rrs = []\n",[m
[32m+[m[32m    "    used_pairs = []\n",[m
[32m+[m[32m    "    skipped_pairs = []\n",[m
[32m+[m[32m    "\n",[m
[32m+[m[32m    "    for query, gold in pairs:\n",[m
[32m+[m[32m    "        if query not in word2idx or gold not in word2idx:\n",[m
[32m+[m[32m    "            skipped_pairs.append((query, gold))\n",[m
[32m+[m[32m    "            continue\n",[m
[32m+[m[32m    "\n",[m
[32m+[m[32m    "        rr = reciprocal_rank(matrix, word2idx, idx2word, query, gold)\n",[m
[32m+[m[32m    "        if rr is not None:\n",[m
[32m+[m[32m    "            rrs.append(rr)\n",[m
[32m+[m[32m    "            used_pairs.append((query, gold, rr))\n",[m
[32m+[m[32m    "\n",[m
[32m+[m[32m    "    mrr = float(np.mean(rrs)) if rrs else 0.0\n",[m
[32m+[m[32m    "    return mrr, used_pairs, skipped_pairs\n",[m
[32m+[m[32m    "\n",[m
[32m+[m[32m    "comparison_rows = []\n",[m
[32m+[m[32m    "\n",[m
[32m+[m[32m    "for cid, result in conditions.items():\n",[m
[32m+[m[32m    "    mrr, used_pairs, skipped_pairs = compute_mrr_verbose(\n",[m
[32m+[m[32m    "        result[\"embeddings\"],\n",[m
[32m+[m[32m    "        result[\"word2idx\"],\n",[m
[32m+[m[32m    "        result[\"idx2word\"],\n",[m
[32m+[m[32m    "        MANUAL_PAIRS\n",[m
[32m+[m[32m    "    )\n",[m
[32m+[m[32m    "\n",[m
[32m+[m[32m    "    comparison_rows.append({\n",[m
[32m+[m[32m    "        \"Condition\": cid,\n",[m
[32m+[m[32m    "        \"Description\": result[\"name\"],\n",[m
[32m+[m[32m    "        \"MRR\": round(mrr, 6),\n",[m
[32m+[m[32m    "        \"Used_Pairs\": len(used_pairs),\n",[m
[32m+[m[32m    "        \"Skipped_Pairs\": len(skipped_pairs)\n",[m
[32m+[m[32m    "    })\n",[m
[32m+[m[32m    "\n",[m
[32m+[m[32m    "comparison_df = pd.DataFrame(comparison_rows).sort_values(\"MRR\", ascending=False)\n",[m
[32m+[m[32m    "\n",[m
[32m+[m[32m    "print(\"Condition comparison with MRR\")\n",[m
[32m+[m[32m    "display(comparison_df)"[m
